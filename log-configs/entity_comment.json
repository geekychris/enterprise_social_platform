{
  "name": "EntityComment",
  "log_type": "entity_comment",
  "version": "1.0.0",
  "description": "CDC events for comment entity changes",
  "kafka": {
    "topic": "worksphere-entity-comments",
    "partitions": 4,
    "replication_factor": 1,
    "retention_ms": 2592000000
  },
  "warehouse": {
    "table_name": "warehouse.comments_hourly",
    "partition_by": ["event_hour"],
    "sort_by": ["event_timestamp", "id"],
    "retention_days": 90
  },
  "fields": [
    {"name": "event_type", "type": "string", "required": true, "description": "CREATE, UPDATE, DELETE"},
    {"name": "event_timestamp", "type": "timestamp", "required": true, "description": "When the change occurred"},
    {"name": "event_hour", "type": "string", "required": true, "description": "Partition key YYYY-MM-DD-HH"},
    {"name": "event_date", "type": "date", "required": true, "description": "Event date"},
    {"name": "id", "type": "long", "required": true, "description": "Comment ID"},
    {"name": "post_id", "type": "long", "required": true, "description": "Parent post ID"},
    {"name": "author_id", "type": "long", "required": true, "description": "Author user ID"},
    {"name": "content", "type": "string", "required": false, "description": "Comment content"},
    {"name": "parent_id", "type": "long", "required": false, "description": "Parent comment ID for nested replies"},
    {"name": "depth", "type": "int", "required": false, "description": "Nesting depth"},
    {"name": "created_at", "type": "string", "required": false, "description": "Entity creation time"}
  ]
}
