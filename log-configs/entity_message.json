{
  "name": "EntityMessage",
  "log_type": "entity_message",
  "version": "1.0.0",
  "description": "CDC events for message entity changes",
  "kafka": {
    "topic": "worksphere-entity-messages",
    "partitions": 4,
    "replication_factor": 1,
    "retention_ms": 2592000000
  },
  "warehouse": {
    "table_name": "warehouse.messages_hourly",
    "partition_by": ["tenant_id", "event_hour"],
    "sort_by": ["event_timestamp", "id"],
    "retention_days": 90
  },
  "fields": [
    {"name": "event_type", "type": "string", "required": true, "description": "CREATE, UPDATE, DELETE"},
    {"name": "event_timestamp", "type": "timestamp", "required": true, "description": "When the change occurred"},
    {"name": "event_hour", "type": "string", "required": true, "description": "Partition key YYYY-MM-DD-HH"},
    {"name": "event_date", "type": "date", "required": true, "description": "Event date"},
    {"name": "tenant_id", "type": "long", "required": false, "description": "Tenant ID for multi-tenant isolation"},
    {"name": "id", "type": "long", "required": true, "description": "Message ID"},
    {"name": "conversation_id", "type": "long", "required": true, "description": "Conversation ID"},
    {"name": "sender_id", "type": "long", "required": true, "description": "Sender user ID"},
    {"name": "content_length", "type": "int", "required": false, "description": "Length of message content (not actual content for privacy)"},
    {"name": "has_attachment", "type": "boolean", "required": false, "description": "Whether message has an attachment"},
    {"name": "created_at", "type": "string", "required": false, "description": "Entity creation time"}
  ]
}
