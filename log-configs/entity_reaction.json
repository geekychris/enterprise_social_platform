{
  "name": "EntityReaction",
  "log_type": "entity_reaction",
  "version": "1.0.0",
  "description": "CDC events for reaction entity changes",
  "kafka": {
    "topic": "worksphere-entity-reactions",
    "partitions": 4,
    "replication_factor": 1,
    "retention_ms": 2592000000
  },
  "warehouse": {
    "table_name": "warehouse.reactions_hourly",
    "partition_by": ["tenant_id", "event_hour"],
    "sort_by": ["event_timestamp", "id"],
    "retention_days": 90
  },
  "fields": [
    {"name": "event_type", "type": "string", "required": true, "description": "CREATE, UPDATE, DELETE"},
    {"name": "event_timestamp", "type": "timestamp", "required": true, "description": "When the change occurred"},
    {"name": "event_hour", "type": "string", "required": true, "description": "Partition key YYYY-MM-DD-HH"},
    {"name": "event_date", "type": "date", "required": true, "description": "Event date"},
    {"name": "tenant_id", "type": "long", "required": false, "description": "Tenant ID for multi-tenant isolation"},
    {"name": "id", "type": "long", "required": true, "description": "Reaction ID"},
    {"name": "user_id", "type": "long", "required": true, "description": "User who reacted"},
    {"name": "target_id", "type": "long", "required": true, "description": "Target entity ID"},
    {"name": "target_type", "type": "string", "required": true, "description": "Target entity type (post, comment, etc)"},
    {"name": "reaction_type", "type": "string", "required": true, "description": "Reaction type (like, love, etc)"},
    {"name": "created_at", "type": "string", "required": false, "description": "Entity creation time"}
  ]
}
